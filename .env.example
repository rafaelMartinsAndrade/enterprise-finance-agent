APP_NAME=Enterprise Finance Agent
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/finance_agent
API_TOKEN=change-me
DEFAULT_ORGANIZATION_SLUG=acme-finance
STORAGE_ROOT=./data/storage
LLM_PROVIDER=mock
LLM_MODEL=gpt-5.6
LLM_API_KEY=
DOCUMENT_ANALYSIS_PROVIDER=mock
CATEGORY_PROVIDER=mock
PROMPT_VERSION=v1-finance-agent
CONFIDENCE_APPROVAL_THRESHOLD=0.72
MAX_AGENT_STEPS=10
TOOL_TIMEOUT_SECONDS=8
TOOL_MAX_RETRIES=2
AGENT_CHECKPOINT_PATH=./data/langgraph/agent_checkpoints.db
MAX_UPLOAD_SIZE_BYTES=3145728
ALLOWED_UPLOAD_TYPES=text/plain,application/pdf,text/markdown,application/json,text/csv
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
STREAMLIT_API_BASE_URL=http://localhost:8000/api/v1
